        </a>
        <a class="btn btn-primary w-full sm:w-36" href="{{ site.home.hero.buttons.quaternary.link }}">
          {{ site.home.hero.buttons.quaternary.text }}
        </a>
      </div>
      {%- include "home/sections/hero/countdown.njk" -%}
    </div>
    {% include "home/sections/hero/hero-graphic.njk" %}
  </div>
</section>
